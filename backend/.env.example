# Copie este arquivo para ".env" e preencha com seus valores reais.
# NUNCA suba o arquivo ".env" (com valores reais) para o GitHub.

# ── Supabase ──
# Painel do projeto → Settings → API
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=cole_aqui_a_service_role_key

# ── OpenAI ──
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-cole_aqui_sua_chave

# ── Servidor ──
PORT=3001

# Domínio do seu frontend, para liberar CORS (separe por vírgula se houver mais de um)
FRONTEND_ORIGIN=http://localhost:5500,http://127.0.0.1:5500
